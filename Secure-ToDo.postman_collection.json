  "item": [
    {
      "name": "Obtener Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.text();\r",
              "// Buscamos el valor dentro del atributo value del input con name=\"csrf_token\"\r",
              "const match = responseBody.match(/name=\"csrf_token\".*value=\"([^\"]+)\"/);\r",
              "\r",
              "if (match) {\r",
              "    // Guardamos el token en la variable de la COLECCIÓN\r",
              "    pm.collectionVariables.set(\"csrf_token\", match[1]);\r",
              "    console.log(\"✅ Token guardado: \" + match[1]);\r",
              "} else {\r",
              "    console.log(\"❌ No se encontró el token en el HTML\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
